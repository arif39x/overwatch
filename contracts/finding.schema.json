{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding",
  "type": "object",
  "properties": {
    "rule_id": { "type": "string" },
    "name": { "type": "string" },
    "severity": { "type": "string" },
    "file": { "type": "string" },
    "line": { "type": "integer", "minimum": 1 },
    "message": { "type": "string" },
    "cwe": { "type": "string" },
    "snippet": { "type": "string" },
    "language": { "type": "string" },
    "confidence": {
      "type": "string",
      "enum": ["DEFINITE", "HIGH_CONFIDENCE", "MEDIUM_CONFIDENCE", "LOW_CONFIDENCE"]
    },
    "fix_guidance": { "type": ["string", "null"] },
    "references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependency_name": { "type": "string" },
    "dependency_version": { "type": "string" },
    "cve_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "occurrence_count": { "type": "integer" },
    "affected_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "poc_verified": { "type": "boolean" },
    "poc_signal": { "type": "string" },
    "poc_status": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["type", "description"]
      }
    },
    "taint_source_identifier": { "type": "string" }
  },
  "required": [
    "rule_id",
    "name",
    "severity",
    "file",
    "line",
    "message",
    "cwe",
    "snippet",
    "language",
    "confidence"
  ]
}
