


OVERWATCH_APP_NAME="Overwatch Backend API"
OVERWATCH_ENVIRONMENT="development"



OVERWATCH_SECRET_KEY="your-secret-key-at-least-16-chars"

OVERWATCH_FERNET_KEY="your-fernet-key-at-least-32-chars-base64"


OVERWATCH_GITHUB_CLIENT_ID=""
OVERWATCH_GITHUB_CLIENT_SECRET=""



OVERWATCH_DATABASE_URL="postgresql+asyncpg://overwatch:password@localhost:5432/overwatch"

OVERWATCH_REDIS_URL="redis://localhost:6379/0"


OVERWATCH_SCANNER_BIN="bin/overwatch"
OVERWATCH_FINDINGS_RANKER_BIN="bin/findings-ranker"



OVERWATCH_AI_PROVIDER="openai"
OVERWATCH_AI_API_KEY=""
OVERWATCH_AI_BASE_URL=""
OVERWATCH_TRIAGE_MODEL="gpt-4o"
OVERWATCH_AI_TRIAGE_MIN_SEVERITY="MEDIUM"
OVERWATCH_ENABLE_PROMPT_GUARDRAILS=false
OVERWATCH_PROMPT_CONTEXT_RADIUS_LINES=20
OVERWATCH_SCAN_RETRY_BASE_DELAY_SECONDS=30
OVERWATCH_SCAN_RETRY_TRANSIENT_MAX=2
OVERWATCH_SCAN_RETRY_RATE_LIMIT_MAX=4
OVERWATCH_SCAN_RETRY_PERMISSION_MAX=0
OVERWATCH_SCAN_RETRY_DETERMINISTIC_MAX=0
OVERWATCH_SCAN_RETRY_UNKNOWN_MAX=1


OVERWATCH_SCAN_TIMEOUT_SECONDS=300
